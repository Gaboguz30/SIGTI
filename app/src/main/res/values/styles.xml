<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="NavIconContainer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="NavIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>

    <style name="NavText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
    </style>
    <style name="SIGTI.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <item name="errorIconDrawable">@drawable/ic_warning</item>
        <item name="errorIconTint">@color/error_red</item>
        <item name="errorTextColor">@color/error_red</item>

        <!-- Esquinas redondeadas uniformes -->
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Variante para dropdowns -->
    <style name="SIGTI.TextInput.Dropdown"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="errorIconDrawable">@drawable/ic_warning</item>
        <item name="errorIconTint">@color/error_red</item>
        <item name="errorTextColor">@color/error_red</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="CustomTabText">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>

    <style name="CardTopRounded">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@animator/dialog_scale</item>
        <item name="android:windowExitAnimation">@animator/dialog_scale</item>
    </style>


</resources>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_checked="true">
        <shape>
            <solid android:color="#EDEDED"/>
            <corners android:radius="20dp"/>
            <padding
                android:left="10dp"
                android:right="10dp"
                android:top="6dp"
                android:bottom="6dp"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>

</selector>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationProvider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- HEADER reutilizado -->
            <include
                android:id="@+id/headerMain"
                layout="@layout/header_main1"/>

            <!-- Subtítulo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Los servicios que ofreces a tus clientes."
                android:fontFamily="@font/poppins_regular"
                android:textColor="#757575"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>

            <!-- Recycler -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProviderCatalog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingBottom="88dp"
                android:nestedScrollingEnabled="false"/>

            <!-- Empty -->
            <TextView
                android:id="@+id/tvEmptyCatalog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aún no tienes servicios.\n¡Agrega uno para empezar a ganar clientes!"
                android:textAlignment="center"
                android:textColor="#9E9E9E"
                android:textSize="16sp"
                android:layout_marginTop="40dp"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddService"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nuevo Servicio"
        app:icon="@android:drawable/ic_input_add"
        android:fontFamily="@font/poppins_bold"
        app:backgroundTint="@color/sigti_blue"
        android:textColor="@color/white"
        app:iconTint="@color/white"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationProvider"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationProvider"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:itemIconTint="@color/selector_nav_blue"
        app:itemTextColor="@color/selector_nav_blue"
        app:labelVisibilityMode="selected"
        app:itemRippleColor="@android:color/transparent"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/provider_bottom_nav_menu" />



</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingTop="28dp"
        android:paddingHorizontal="28dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mi Catálogo"
            android:fontFamily="@font/poppins_bold"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Los servicios que ofreces a tus clientes."
            android:fontFamily="@font/poppins_medium"
            android:textColor="#757575"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProviderCatalog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="88dp"/>

        <TextView
            android:id="@+id/tvEmptyCatalog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aún no tienes servicios.\n¡Agrega uno para empezar a ganar clientes!"
            android:textAlignment="center"
            android:textColor="#9E9E9E"
            android:textSize="16sp"
            android:layout_marginTop="40dp"
            android:visibility="gone" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddService"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nuevo Servicio"
        app:icon="@android:drawable/ic_input_add"
        android:fontFamily="@font/poppins_bold"
        app:backgroundTint="@color/sigti_blue"
        android:textColor="@color/white"
        app:iconTint="@color/white"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationProvider"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationProvider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:itemIconTint="@color/selector_nav_blue"
        app:itemTextColor="@color/selector_nav_blue"
        app:labelVisibilityMode="labeled"
        app:itemRippleColor="@android:color/transparent"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/provider_bottom_nav_menu" />


</androidx.constraintlayout.widget.ConstraintLayout>
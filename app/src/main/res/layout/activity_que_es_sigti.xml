<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnSiguiente"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- HEADER -->
            <include
                android:id="@+id/header"
                layout="@layout/header_main"/>

            <!-- 🔵 BARRITAS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="40dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@color/sigti_blue"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="#E0E0E0"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="#E0E0E0"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="#E0E0E0"/>
            </LinearLayout>

            <!-- DESCRIPCION -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SIGTI es una app para ofrecer servicios a domicilio como plomería, electricidad, carpintería y más."
                android:textSize="15sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="#424242"
                android:layout_marginBottom="20dp"/>

            <!-- IMAGEN -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:src="@drawable/fondop"
                android:scaleType="centerCrop"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card"/>

            <!-- TEXTO FINAL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Para ofrecer tu servicio, crea tu servicio en el catálogo de la categoría que deseas y empieza a ganar dinero con nosotros."
                android:textSize="15sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="#424242"/>

        </LinearLayout>

    </ScrollView>

    <!-- 🔵 BOTON SIGUIENTE -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSiguiente"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Siguiente"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:fontFamily="@font/poppins_medium"
        android:backgroundTint="@color/sigti_blue"
        app:cornerRadius="12dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="28dp"
    android:gravity="center"
    android:background="@color/white">

    <!-- Logo -->

    <!-- Texto términos -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginBottom="20dp"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_sig_principal" />

    <TextView
        android:id="@+id/al_hacer_cl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#757575"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_regular"
        android:lineSpacingExtra="4dp"
        android:text="Al hacer clic en continuar, aceptas nuestros Términos de Servicio y Política de Privacidad" />

    <!-- Botón principal -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAcceptContinue"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="22dp"
        android:backgroundTint="@color/sigti_blue"
        android:text="Aceptar y continuar"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_medium"
        android:elevation="6dp"
        app:cornerRadius="20dp" />

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="18dp"
        android:background="#E0E0E0"/>

    <!-- Google -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="@color/social_button_bg"
        app:cornerRadius="16dp"
        app:icon="@drawable/icon_google"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="@null"
        android:text="Continuar con Google"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_medium" />

    <!-- Facebook -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFacebook"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/social_button_bg"
        app:cornerRadius="16dp"
        app:icon="@drawable/icon_facebook"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="@null"
        android:text="Continuar con Facebook"
        android:textColor="@color/black"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_medium" />

    <!-- Login -->
    <TextView
        android:id="@+id/tvLoginLink"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="¿Ya tienes cuenta? Iniciar sesión"
        android:textColor="@color/sigti_blue"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_medium" />

</LinearLayout>
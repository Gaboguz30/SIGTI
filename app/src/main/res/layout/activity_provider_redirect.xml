<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/white">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/logo_sig_principal"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registro de Prestador"
        android:textSize="22sp"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/black"
        android:textAlignment="center"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Para garantizar la seguridad de nuestra comunidad, el registro de prestadores se realiza exclusivamente a través de nuestro portal web oficial."
        android:textSize="16sp"
        android:fontFamily="@font/poppins_regular"
        android:textColor="#616161"
        android:textAlignment="center"/>

    <TextView
        android:id="@+id/tvRedirectMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Serás redireccionado en unos momentos"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/sigti_blue"
        android:textAlignment="center"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoToWeb"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Ir a la web ahora"
        app:cornerRadius="28dp"
        android:backgroundTint="@color/sigti_blue"
        android:fontFamily="@font/poppins_bold"/>
</LinearLayout>
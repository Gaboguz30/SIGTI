<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <LinearLayout
        android:id="@+id/header"
        android:paddingBottom="40dp"
        android:layout_width="0dp"
        android:layout_marginBottom="4dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_header_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hola"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_regular"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Qué necesitas hoy?"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:fontFamily="@font/poppins_bold"/>


    </LinearLayout>


    <LinearLayout
        android:id="@+id/searchContainer"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="-26dp"
        android:background="@drawable/bg_search_input"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:elevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#8E8E93"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@null"
            android:hint="Buscar plomero, electricista..."
            android:textColor="#000000"
            android:textColorHint="#8E8E93"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"
            android:padding="0dp"
            android:textCursorDrawable="@null"
            android:importantForAutofill="no"
            android:inputType="text"/>
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/hsvOficios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/searchContainer">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="10dp">

            <!-- Plomero -->
            <LinearLayout
                android:id="@+id/catPlomero"
                android:layout_width="80dp"
                android:layout_height="45dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_category"
                android:orientation="vertical"
                android:gravity="center"
                android:elevation="3dp">

                <ImageView
                    android:id="@+id/iconPlomero"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_manage"
                    app:tint="#2563EB"/>

                <TextView
                    android:id="@+id/textPlomero"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plomero"
                    android:layout_marginTop="4dp"
                    android:textSize="10sp"
                    android:textColor="#374151"
                    android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>

            <!-- Electricista -->
            <LinearLayout
                android:id="@+id/catElectricista"
                android:layout_width="80dp"
                android:layout_height="45dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_category"
                android:orientation="vertical"
                android:gravity="center"
                android:elevation="3dp">

                <ImageView
                    android:id="@+id/iconElectricista"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_compass"
                    app:tint="#2563EB"/>

                <TextView
                    android:id="@+id/textElectricista"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Electricista"
                    android:layout_marginTop="4dp"
                    android:textSize="10sp"
                    android:textColor="#374151"
                    android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>

            <!-- Albañil -->
            <LinearLayout
                android:id="@+id/catAlbanil"
                android:layout_width="80dp"
                android:layout_height="45dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_category"
                android:orientation="vertical"
                android:gravity="center"
                android:elevation="3dp">

                <ImageView
                    android:id="@+id/iconAlbanil"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="#2563EB"/>

                <TextView
                    android:id="@+id/textAlbanil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Albañil"
                    android:layout_marginTop="4dp"
                    android:textSize="11sp"
                    android:textColor="#374151"
                    android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>

            <!-- Carpintero -->
            <LinearLayout
                android:id="@+id/catCarpintero"
                android:layout_width="80dp"
                android:layout_height="45dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_category"
                android:orientation="vertical"
                android:gravity="center"
                android:elevation="3dp">

                <ImageView
                    android:id="@+id/iconCarpintero"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_crop"
                    app:tint="#2563EB"/>

                <TextView
                    android:id="@+id/textCarpintero"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carpintero"
                    android:layout_marginTop="4dp"
                    android:textSize="10sp"
                    android:textColor="#374151"
                    android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>

            <!-- Pintor -->
            <LinearLayout
                android:id="@+id/catPintor"
                android:layout_width="80dp"
                android:layout_height="45dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_category"
                android:orientation="vertical"
                android:gravity="center"
                android:elevation="3dp">

                <ImageView
                    android:id="@+id/iconPintor"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="#2563EB"/>

                <TextView
                    android:id="@+id/textPintor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pintor"
                    android:layout_marginTop="4dp"
                    android:textSize="10sp"
                    android:textColor="#374151"
                    android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWorkers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/hsvOficios"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        tools:listitem="@layout/item_worker"/>



    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/selector_nav_blue"
        app:itemTextColor="@color/selector_nav_blue"
        app:labelVisibilityMode="labeled"
        app:itemRippleColor="@android:color/transparent"/>






</androidx.constraintlayout.widget.ConstraintLayout>
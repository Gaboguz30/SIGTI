<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EAEAEA"
    app:cardBackgroundColor="@color/white"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivWorkerProfile"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="#F5F5F5"
            android:src="@android:drawable/ic_menu_gallery"
            android:padding="12dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvWorkerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre Apellido"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/tvWorkerProfession"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Especialidad"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/star_on"
                    app:tint="#FFC107"/> <TextView
                android:id="@+id/tvWorkerRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.8"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="12dp"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_dialog_map"
                    app:tint="#9E9E9E"/>

                <TextView
                    android:id="@+id/tvWorkerDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 km"
                    android:textSize="14sp"
                    android:textColor="#757575"
                    android:layout_marginStart="4dp"/>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvWorkerPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$250/hr"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/sigti_blue"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewProfile"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver Perfil"
        android:textColor="@color/sigti_blue"
        app:strokeColor="@color/sigti_blue"
        app:strokeWidth="1dp"
        app:cornerRadius="10dp"
        android:layout_marginTop="16dp"/>

</LinearLayout>
</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    android:background="@color/white"
    app:strokeColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivWorkerProfile"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/ic_launcher_background"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tvWorkerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="-15dp"
            android:text="Nombre del Prestador"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tvWorkerPrice"
            app:layout_constraintStart_toEndOf="@+id/ivWorkerProfile"
            app:layout_constraintTop_toTopOf="@+id/ivWorkerProfile" />

        <TextView
            android:id="@+id/tvWorkerProfession"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Oficio"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@+id/tvWorkerName"
            app:layout_constraintTop_toBottomOf="@+id/tvWorkerName" />

        <TextView
            android:id="@+id/tvWorkerAvailability"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disponibilidad: Hoy"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@+id/tvWorkerName"
            app:layout_constraintTop_toBottomOf="@+id/tvWorkerProfession" />

        <TextView
            android:id="@+id/tvWorkerRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="★ 4.8"
            android:textColor="#FFB300"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/tvWorkerName"
            app:layout_constraintTop_toBottomOf="@+id/tvWorkerAvailability" />

        <TextView
            android:id="@+id/tvWorkerDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="2 km"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@+id/tvWorkerRating"
            app:layout_constraintStart_toEndOf="@+id/tvWorkerRating"
            app:layout_constraintTop_toTopOf="@+id/tvWorkerRating" />

        <TextView
            android:id="@+id/tvWorkerPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="$250\ndesde"
            android:textAlignment="viewEnd"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewProfile"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginTop="40dp"
            android:text="Ver Perfil"
            android:backgroundTint="@color/sigti_blue"
            android:textSize="12sp"
            app:cornerRadius="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvWorkerPrice" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
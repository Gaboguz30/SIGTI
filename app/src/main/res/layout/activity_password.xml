<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="28dp">

    <!-- LOGO -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="end"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/app_name"
        android:src="@drawable/logo_sig_principal"
        android:scaleType="centerInside"/>

    <!-- TÍTULO -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crea tu seguridad"
        android:textSize="30sp"
        android:textColor="@color/black"
        android:fontFamily="@font/poppins_bold"
        android:layout_marginBottom="6dp"/>

    <!-- SUBTEXTO -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Esta será la llave para entrar a tu cuenta en SIGTI."
        android:textColor="#757575"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginBottom="28dp"/>

    <!-- PASSWORD -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPassword"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nueva contraseña"
        android:layout_marginBottom="16dp"
        app:startIconDrawable="@android:drawable/ic_lock_lock"
        app:startIconTint="@color/sigti_blue"
        app:endIconMode="password_toggle"
        app:boxStrokeColor="@color/sigti_blue"
        app:boxStrokeWidthFocused="2dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- CONFIRM PASSWORD -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilConfirmPassword"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Confirmar contraseña"
        android:layout_marginBottom="10dp"
        app:startIconDrawable="@android:drawable/ic_lock_lock"
        app:startIconTint="@color/sigti_blue"
        app:endIconMode="password_toggle"
        app:boxStrokeColor="@color/sigti_blue"
        app:boxStrokeWidthFocused="2dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- HINT -->
    <TextView
        android:id="@+id/tvPasswordHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mínimo 8 caracteres, una mayúscula y un número."
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginBottom="20dp"/>

    <!-- CHECKBOX -->
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cbRecuerdame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recordar sesión en este dispositivo"
        android:textColor="#555555"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_regular"
        app:buttonTint="@color/sigti_blue"
        android:layout_marginBottom="30dp"/>

    <!-- BOTÓN -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinuar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Crear cuenta y finalizar"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_medium"
        app:backgroundTint="@color/sigti_blue"
        app:cornerRadius="22dp"/>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="end"
        android:contentDescription="@string/app_name"
        android:src="@drawable/logo_sigti_2"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_gravity="center">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="28sp"
            android:textStyle="bold"
            android:text="¿Cómo deseas usar SIGTI?" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:layout_marginTop="5dp"
            android:text="(Puedes elegir una o ambas opciones)" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnPrestador"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:checkable="true"
            app:cardBackgroundColor="@color/blue_primary"
            app:cardCornerRadius="18dp"
            app:cardElevation="10dp"
            app:strokeColor="@color/white"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <View
                    android:id="@+id/viewIconBg1"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/icon_prestador_de_servicios"
                    tools:ignore="MissingConstraints" />

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    app:layout_constraintBottom_toBottomOf="@id/viewIconBg1"
                    app:layout_constraintEnd_toEndOf="@id/viewIconBg1"
                    app:layout_constraintStart_toStartOf="@id/viewIconBg1"
                    app:layout_constraintTop_toTopOf="@id/viewIconBg1"
                    app:tint="@color/blue_primary" />

                <TextView
                    android:id="@+id/tvRole1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Prestador Servicios"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/viewIconBg1"
                    app:layout_constraintTop_toTopOf="@id/viewIconBg1" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Ofrezco mis servicios y recibo solicitudes"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="@id/tvRole1"
                    app:layout_constraintTop_toBottomOf="@id/tvRole1" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnSolicitante"
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:checkable="true"
            app:cardBackgroundColor="@color/blue_primary"
            app:cardCornerRadius="18dp"
            app:cardElevation="10dp"
            app:strokeColor="@color/white"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <View
                    android:id="@+id/viewIconBg2"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/icon_solicitante_servicio"
                    tools:ignore="MissingConstraints" />

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    app:layout_constraintBottom_toBottomOf="@id/viewIconBg2"
                    app:layout_constraintEnd_toEndOf="@id/viewIconBg2"
                    app:layout_constraintStart_toStartOf="@id/viewIconBg2"
                    app:layout_constraintTop_toTopOf="@id/viewIconBg2"
                    app:tint="@color/blue_primary" />

                <TextView
                    android:id="@+id/tvRole2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Solicitante de Servicios"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/viewIconBg2"
                    app:layout_constraintTop_toTopOf="@id/viewIconBg2" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Busco contratar un oficio"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/tvRole2"
                    app:layout_constraintTop_toBottomOf="@id/tvRole2" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>
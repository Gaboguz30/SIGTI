<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet">

    <View
    android:layout_width="40dp"
    android:layout_height="4dp"
    android:background="#E5E7EB"
    android:layout_gravity="center_horizontal"
    android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Califica tu experiencia"
        android:textSize="20sp"
        android:fontFamily="@font/poppins_bold"
        android:textColor="#111827"
        android:textAlignment="center"
        android:layout_marginBottom="16dp"/>

    <RatingBar
        android:id="@+id/rbNewReview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="1.0"
        android:rating="0"
        android:progressTint="#FACC15"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/sigti_blue"
        android:hint="Escribe tu reseña..."
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etReviewComment"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:fontFamily="@font/poppins_regular"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddPhoto"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Agrega una Foto (Opcional)"
        app:icon="@android:drawable/ic_menu_camera"
        android:textColor="#4B5563"
        app:iconTint="#4B5563"
        app:strokeColor="#D1D5DB"
        app:cornerRadius="12dp"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitReview"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Publicar Reseña"
        android:textColor="@color/white"
        app:backgroundTint="@color/sigti_blue"
        app:cornerRadius="12dp"
        android:fontFamily="@font/poppins_bold"/>

</LinearLayout>
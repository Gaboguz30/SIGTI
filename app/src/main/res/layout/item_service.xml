<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"

    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E5E7EB"

    android:backgroundTint="@android:color/white"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="18dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@color/sigti_blue"
            android:background="#EEF2FF"
            android:padding="10dp"
            android:layout_marginEnd="16dp"/>

        <!-- TEXTO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvServiceTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mantenimiento preventivo"
                android:fontFamily="@font/poppins_medium"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#111827"/>

            <TextView
                android:id="@+id/tvServiceDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Revisión general y limpieza de equipos."
                android:fontFamily="@font/poppins_regular"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- PRECIO -->
        <TextView
            android:id="@+id/tvServicePrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$500"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2563EB"
            android:background="#EFF6FF"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:layout_marginStart="12dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
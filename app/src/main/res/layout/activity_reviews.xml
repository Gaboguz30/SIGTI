<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="@color/white"
    android:background="#FAFAFA">

    <ImageView
        android:id="@+id/btnBackReviews"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/ic_retorno"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black" />

    <TextView
        android:id="@+id/tvReviewsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Reseñas"
        android:textColor="@color/black"
        android:fontFamily="@font/poppins_bold"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBackReviews"
        app:layout_constraintStart_toEndOf="@+id/btnBackReviews"
        app:layout_constraintTop_toTopOf="@+id/btnBackReviews" />

    <TextView
        android:id="@+id/btnWriteReview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:text="Escribir reseña"
        android:fontFamily="@font/poppins_medium"
        android:textColor="#1976D2"
        app:layout_constraintBottom_toBottomOf="@+id/tvReviewsTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvReviewsTitle" />

    <TextView
        android:id="@+id/tvReviewsSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vianca Ramírez"
        android:fontFamily="@font/poppins_medium"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@+id/tvReviewsTitle"
        app:layout_constraintTop_toBottomOf="@+id/tvReviewsTitle" />

    <TextView
        android:id="@+id/tvBigStar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:text="★"
        android:textColor="#FFB300"
        android:textSize="40sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvReviewsSubtitle" />

    <TextView
        android:id="@+id/tvBigRating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="4.8"
        android:textColor="@color/black"
        android:textSize="40sp"
        android:fontFamily="@font/poppins_bold"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/tvBigStar"
        app:layout_constraintStart_toEndOf="@+id/tvBigStar"
        app:layout_constraintTop_toTopOf="@+id/tvBigStar" />

    <TextView
        android:id="@+id/tvTotalReviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="123 Reseñas\n98% Recomendado"
        android:fontFamily="@font/poppins_regular"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/tvBigRating"
        app:layout_constraintStart_toEndOf="@+id/tvBigRating"
        app:layout_constraintTop_toTopOf="@+id/tvBigRating" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReviews"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigationReviews"
        app:layout_constraintTop_toBottomOf="@+id/tvBigRating"
        tools:listitem="@layout/item_review" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationReviews"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
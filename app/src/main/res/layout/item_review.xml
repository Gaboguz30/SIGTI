<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F3F4F6"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivReviewAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#E5E7EB"
            android:padding="8dp"
            android:src="@drawable/ic_profile"
            app:tint="#9CA3AF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvReviewUser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/poppins_bold"
            android:textColor="#111827"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@+id/tvReviewDate"
            app:layout_constraintStart_toEndOf="@id/ivReviewAvatar"
            app:layout_constraintTop_toTopOf="@id/ivReviewAvatar"
            tools:text="Carlos Mendoza" />

        <RatingBar
            android:id="@+id/rbReviewStars"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:isIndicator="true"
            android:numStars="5"
            android:progressTint="#FACC15"
            android:stepSize="0.5"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="@id/tvReviewUser"
            app:layout_constraintTop_toBottomOf="@id/tvReviewUser"
            tools:rating="4.5" />

        <TextView
            android:id="@+id/tvReviewDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvReviewUser"
            tools:text="12 Oct 2026" />

        <TextView
            android:id="@+id/tvReviewComment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="#374151"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvReviewUser"
            app:layout_constraintTop_toBottomOf="@id/rbReviewStars"
            tools:text="Excelente servicio, llegó a tiempo y resolvió el problema del cableado." />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivReviewPhoto"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:cornerFamily="rounded"
            app:cornerSize="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvReviewUser"
            app:layout_constraintTop_toBottomOf="@id/tvReviewComment"
            tools:background="#E5E7EB"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
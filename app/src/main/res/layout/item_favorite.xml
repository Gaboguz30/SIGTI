<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#E5E7EB"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- FOTO -->
        <FrameLayout
            android:id="@+id/framePhoto"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/imgFoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile"
                android:background="@drawable/bg_circle"/>
        </FrameLayout>

        <!-- CORAZÓN -->
        <ImageView
            android:id="@+id/btnFavorito"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_favorite"
            app:tint="#2563EB"
            android:padding="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/framePhoto"
            app:layout_constraintBottom_toBottomOf="@id/framePhoto"/>

        <!-- CONTENEDOR DE TEXTO (CLAVE PARA CENTRADO) -->
        <LinearLayout
            android:id="@+id/layoutTexto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="6dp"
            app:layout_constraintStart_toEndOf="@id/framePhoto"
            app:layout_constraintEnd_toStartOf="@id/btnFavorito"
            app:layout_constraintTop_toTopOf="@id/framePhoto"
            app:layout_constraintBottom_toBottomOf="@id/framePhoto">

            <!-- NOMBRE -->
            <TextView
                android:id="@+id/txtNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre Prestador"
                android:textStyle="bold"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_medium"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- SERVICIO -->
            <TextView
                android:id="@+id/txtServicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Electricista"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="2dp"/>

            <!-- DISPONIBILIDAD -->
            <TextView
                android:id="@+id/txtDisponibilidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disponible"
                android:textSize="11sp"
                android:textColor="#16A34A"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="end"
            android:contentDescription="@string/app_name"
            android:src="@drawable/logo_sigti_2"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Perfil Profesional"
            android:textSize="32sp"  android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completa estos datos para que los clientes confíen en tu trabajo."
            android:textColor="#757575"
            android:textSize="16sp"
            android:layout_marginBottom="40dp"/> <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ciudad de operación"
            android:layout_marginBottom="24dp"
            app:startIconDrawable="@android:drawable/ic_dialog_map"
            app:startIconTint="@color/sigti_blue"
            app:boxCornerRadiusTopStart="12dp"  app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCiudad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:paddingStart="48dp"
                android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tus Oficios"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/llOficiosContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddOficio"
            style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Agregar otro oficio"
            android:textColor="@color/sigti_blue"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_gravity="start"
            android:layout_marginBottom="40dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Identificación Oficial (INE)"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnUploadIne"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp" app:strokeWidth="2dp"
            app:strokeColor="#DDDDDD" android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/sigti_blue"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toca para subir foto de INE"
                    android:textColor="@color/sigti_blue"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvIneStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ningún archivo seleccionado"
            android:textAlignment="center"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:layout_marginBottom="48dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinuarExtra"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Continuar a Contraseña"
            android:textSize="18sp"
            android:textAllCaps="false"
            app:backgroundTint="@color/sigti_blue"
            app:cornerRadius="16dp"  app:elevation="4dp"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

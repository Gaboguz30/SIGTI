<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- BACK -->
    <ImageView
        android:id="@+id/btnBackChat"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:src="@android:drawable/ic_menu_revert"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        app:tint="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- TITULO -->
    <TextView
        android:id="@+id/tvChatTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chat"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:fontFamily="@font/poppins_bold"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/btnBackChat"
        app:layout_constraintTop_toTopOf="@id/btnBackChat"
        app:layout_constraintBottom_toBottomOf="@id/btnBackChat"/>

    <!-- SUBTITULO -->
    <TextView
        android:id="@+id/tvChatSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vianca Ramírez"
        android:textSize="12sp"
        android:textColor="#757575"
        android:fontFamily="@font/poppins_regular"
        app:layout_constraintStart_toStartOf="@id/tvChatTitle"
        app:layout_constraintTop_toBottomOf="@id/tvChatTitle"/>

    <!-- SEGURIDAD -->
    <TextView
        android:id="@+id/btnSecurity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seguridad"
        android:textColor="@color/sigti_blue"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_medium"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvChatTitle"/>

    <!-- WARNING -->
    <TextView
        android:id="@+id/tvChatWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:text="Consejo: no compartas datos sensibles o reporta conductas inapropiadas."
        android:textAlignment="center"
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:fontFamily="@font/poppins_regular"
        app:layout_constraintTop_toBottomOf="@id/tvChatSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvUnreadBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3 mensajes no leídos"
        android:textColor="@android:color/white"
        android:background="#1976D2"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvChatWarning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- MENSAJES -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvUnreadBanner"
        app:layout_constraintBottom_toTopOf="@id/llInputArea"/>

    <!-- INPUT -->
    <LinearLayout
        android:id="@+id/llInputArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="6dp"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationChat">

        <EditText
            android:id="@+id/etMessageInput"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/rounded_edittext"
            android:hint="Escribe tu mensaje..."
            android:textSize="14sp"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="14dp"/>

        <!-- BOTÓN PRO (EL QUE TE GUSTABA) -->
        <ImageView
            android:id="@+id/btnSendMessage"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_send_circle"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@color/white"/>
    </LinearLayout>

    <!-- NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationChat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
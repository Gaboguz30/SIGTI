<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- 🔽 SCROLL SOLO PARA HEADER -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollTop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="24dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <include
                android:id="@+id/header"
                layout="@layout/header_main"/>

            <TextView
                android:id="@+id/tvChatSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En línea"
                android:textSize="12sp"
                android:textColor="#757575"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginStart="16dp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvUnreadBanner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 mensajes no leídos"
                android:textColor="@android:color/white"
                android:background="#1976D2"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 🔥 CHAT (FUERA DEL SCROLL) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/white"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/scrollTop"
        app:layout_constraintBottom_toTopOf="@id/llInputArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- INPUT -->
    <LinearLayout
        android:id="@+id/llInputArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="6dp"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationChat"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etMessageInput"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/rounded_edittext"
            android:hint="Escribe tu mensaje..."
            android:textSize="14sp"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="14dp"/>

        <ImageView
            android:id="@+id/btnSendMessage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_send_circle"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@color/white"/>
    </LinearLayout>

    <!-- NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationChat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:itemIconTint="@color/selector_nav_blue"
        app:itemTextColor="@color/selector_nav_blue"
        app:labelVisibilityMode="labeled"
        app:itemRippleColor="@android:color/transparent"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:menu="@menu/bottom_nav_menu"/>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="12/04/2026"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendiente"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_category"
                android:textColor="@color/sigti_blue"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvRoleContext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contexto"
            android:textSize="11sp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/poppins_bold"/>

        <TextView
            android:id="@+id/tvIncidentType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tipo de Incidente"
            android:textColor="#212121"
            android:textSize="16sp"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/poppins_bold"/>

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción breve del reporte..."
            android:textColor="#616161"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_regular"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>